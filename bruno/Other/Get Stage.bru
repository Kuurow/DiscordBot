meta {
  name: Get Stage
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/stage/main_00-01
  body: none
  auth: none
}

docs {
  Returns normal stage data including map tiles, enemy spawns, and objectives.
  Also available: GET /toughstage/:id for challenge mode versions.
  Tile types are mapped via gameConsts.tileDict in constants.json (emoji + display name).
  Not yet implemented in the bot — endpoint available for future /stage command.
}
