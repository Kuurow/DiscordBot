meta {
  name: Get Recruit Pool
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/recruitpool
  body: none
  auth: none
}

docs {
  Returns a single document whose value is an array of currently recruitable operator ID strings (~170 IDs).
  Response: [{ canon: "recruitpool", value: ["char_285_medic2", ...] }]
  Cross-reference each ID with GET /operator/:id to get name, rarity, and tagList.
  Used by utils/recruitCache.js to build the recruitment simulator pool.
}
